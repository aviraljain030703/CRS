# ========================================================================
# MySQL Production Configuration
# ========================================================================
#
# This file contains production-optimized MySQL settings
# Place this in /etc/mysql/conf.d/my-prod.cnf or bind mount in Docker
#
# ========================================================================

[mysqld]

# ── Connection Settings ────────────────────────────────────────────────
max_connections = 200
max_allowed_packet = 256M
thread_stack = 192K
thread_cache_size = 8

# ── Performance Settings ───────────────────────────────────────────────
# Query cache disabled (deprecated in MySQL 8.0+)
# query_cache_size = 0
# query_cache_type = 0

# Buffer pool size - set to 50-80% of available RAM
# For 4GB RAM: innodb_buffer_pool_size = 3G
innodb_buffer_pool_size = 2G
innodb_log_file_size = 512M

# InnoDB settings
innodb_file_per_table = 1
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# ── Binary Logging for Replication & Backups ──────────────────────────
server-id = 1
log_bin = /var/log/mysql/mysql-bin.log
binlog_format = MIXED
expire_logs_days = 30

# ── Slow Query Logging ─────────────────────────────────────────────────
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2
log_queries_not_using_indexes = 1

# ── General Logging (Disable in production for performance) ────────────
general_log = 0
general_log_file = /var/log/mysql/mysql.log

# ── Error Logging ──────────────────────────────────────────────────────
log_error = /var/log/mysql/mysql-error.log

# ── Security Settings ──────────────────────────────────────────────────
# Disable symbolic links
symbolic-links = 0

# Skip reverse DNS lookups
skip-name-resolve

# Require passwords for all users
sql_mode = "STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION"

# ── Character Set ─────────────────────────────────────────────────────
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

[mysqldump]
quick
quote-names
max_allowed_packet = 256M

[mysql]
# no-auto-rehash

[isamchk]
key_buffer_size = 16M
